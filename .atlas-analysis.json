  "keyFeatures": [
    "Container-isolated agent execution with filesystem sandboxing",
    "WhatsApp, Telegram, Discord, Slack, and Gmail support",
    "Per-group isolated context and memory (CLAUDE.md)",
    "Scheduled tasks with cron expressions",
    "Agent Swarms - collaborative multi-agent teams",
    "Skills-based customization system",
    "Web search and content fetching",
    "Read-only project root mounting for security",
    "IPC-based message routing and task management",
    "SQLite-based state and message storage"
  ],
  "publicApiSurface": [
    "WhatsAppChannel.connect()",
    "WhatsAppChannel.sendMessage(jid, text)",
    "runContainerAgent(group, config, registerProcess, onOutput)",
